# ─────────────────────────────────────────────────────────────────────────────
# Laundry App — Environment Variables
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────────────────────────
# Root password for the MySQL container (used by the healthcheck probe)
MYSQL_ROOT_PASSWORD=abdourz15@

# Database name (must match what Spring Boot connects to)
MYSQLDATABASE=laundry-app

# Application-level MySQL user (lower privilege than root)
MYSQLUSER=astrapropreP
MYSQLPASSWORD=Abdou&astrapropreP

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 256-bit (32 bytes) Base64-encoded secret.
# Generate with: openssl rand -base64 32
JWT_SECRET=jCdcF7D/92r4dwyNBo17kpUktUj8dpSZ/nxRAynlejk=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API and WebSocket.
# Use your actual domain(s) in production — NO trailing slash.
# Example: https://myapp.example.com
# For local testing you can use: http://localhost:8081,http://192.168.1.x:8081
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://192.168.1.83:8081,http://192.168.1.83:19000

# ── First-run Admin Seed (optional) ──────────────────────────────────────────
# If set, DataInitializer creates this admin account on first startup.
# Leave blank (or remove) after the account has been created — it is idempotent.
SEED_ADMIN_EMAIL=moha@example.com
SEED_ADMIN_PASSWORD=moha1234
SEED_ADMIN_NAME=Mohamed
